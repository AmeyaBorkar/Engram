# Engram bench-harness environment variables.
#
# Copy this file to `.env` (which is gitignored) and fill in the keys
# you need. The bench CLI auto-loads `.env` before resolving the
# provider, so you don't have to set anything in your shell.
#
# You only need the keys for the providers you actually use:
#   * OpenAI       -- embeddings (always required for real-provider runs)
#                     + chat (when --chat openai)
#   * Anthropic    -- chat only (when --chat anthropic)
#   * Moonshot     -- chat only (when --chat moonshot, for Kimi K2.x direct)
#   * OpenCode Zen -- chat only (when --chat opencode-zen). One key gives
#                     access to Claude, GPT 5.x, and Kimi K2.x through
#                     a single OpenAI-compatible endpoint.
#
# Existing environment variables take precedence over `.env`, so you
# can override per-shell without editing this file.

# OpenAI -- https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic -- https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Moonshot / Kimi -- https://platform.moonshot.ai/
# (Optional; only needed if you run with --chat moonshot)
MOONSHOT_API_KEY=ms-...

# OpenCode Zen -- https://opencode.ai/
# (Optional; only needed if you run with --chat opencode-zen)
OPENCODE_ZEN_API_KEY=...

# LongMemEval suite knobs (optional; defaults are fine).
# LONGMEMEVAL_MAX_QUESTIONS=10   # cap for smoke runs; unset = all 500
# LONGMEMEVAL_K=10               # retrieval top-k
